{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "theme": "dark",

  "permissions": {
    "allow": [
      "Read(//Users/moonz/MoonzWorkspace/**)",
      "Read(//Users/moonz/Library/Application Support/Claude/**)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(find *)",
      "mcp__filesystem__*",
      "mcp__github__*",
      "mcp__cognee__*",
      "mcp__codegraph__*"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/vault/**)",
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ]
  },

  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@latest",
        "/Users/moonz/MoonzWorkspace"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "cognee": {
      "command": "/Users/moonz/MoonzWorkspace/Claude_up/09-cognee/.venv/bin/cognee-mcp",
      "args": ["--transport", "stdio"],
      "env": {
        "LLM_API_KEY": "${env:DASHSCOPE_API_KEY}",
        "LLM_PROVIDER": "openai",
        "LLM_MODEL": "openai/qwen-plus",
        "LLM_ENDPOINT": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "EMBEDDING_PROVIDER": "openai_compatible",
        "EMBEDDING_API_KEY": "${env:DASHSCOPE_API_KEY}",
        "EMBEDDING_MODEL": "text-embedding-v3",
        "EMBEDDING_DIMENSIONS": "1024",
        "EMBEDDING_BATCH_SIZE": "10",
        "EMBEDDING_ENDPOINT": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "DATA_ROOT_DIRECTORY": "/Users/moonz/MoonzWorkspace/Claude_up/09-cognee/.data_storage",
        "SYSTEM_ROOT_DIRECTORY": "/Users/moonz/MoonzWorkspace/Claude_up/09-cognee/.cognee_system",
        "ENABLE_BACKEND_ACCESS_CONTROL": "false"
      }
    }
  },

  "_pending_mcpServers": {
    "_note": "需要先在 Mac 安装后端再迁入 mcpServers：codegraph 需安装 codegraph 二进制并在项目内 `codegraph init -i`。cognee 已启用并端到端打通（venv 隔离 09-cognee/.venv，DASHSCOPE_API_KEY 见 .zshrc + launchctl）。",
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    }
  },

  "_archived_mcpServers": {
    "letta": {
      "_note": "归档于 2026-05-18，被 cognee 替代。需常驻服务器(localhost:8283)，复杂度过高。",
      "command": "letta-mcp",
      "args": [],
      "env": {
        "LETTA_BASE_URL": "http://localhost:8283/v1",
        "LETTA_PASSWORD": ""
      }
    }
  },

  "_deferred_hooks_note": "Windows 版 settings.json 含 4 个 PowerShell hooks（pre-bash-audit / post-write-format / post-write-research / stop-session-summary）。Mac 端需改写为 bash 后再启用，源在 ~/MoonzWorkspace/Claude_up/04-hooks/。这 4 个仍暂不部署；SessionStart 记忆注入 hook 已于 2026-06-08 部署（见下方 hooks 块）。",

  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          { "type": "command", "command": "/Users/moonz/.claude/hooks/inject-memory.sh" }
        ]
      }
    ]
  },

  "autoUpdates": true,
  "verbose": false,
  "skipWorkflowUsageWarning": true
}
